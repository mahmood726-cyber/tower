#!/usr/bin/env bash
#
# Tower CLI - Research Workflow Made Simple
#
# Usage:
#   tower status          Show all cards
#   tower new [desc]      Create a new card
#   tower run "cmd"       Run a command under current card
#   tower check [card]    Check gates for a card
#   tower pack [card]     Generate proofpack
#   tower merge [card]    Merge a GOLD card (in merge window)
#   tower help            Show help
#

set -e

# ============================================================
# Configuration
# ============================================================

TOWER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TOWER_DIR/scripts"
CONTROL_DIR="$TOWER_DIR/control"
STATUS_FILE="$CONTROL_DIR/status.json"

# Detect Python
if command -v python3 &> /dev/null; then
    PYTHON_CMD="python3"
elif command -v python &> /dev/null; then
    PYTHON_CMD="python"
else
    PYTHON_CMD=""
fi

# ============================================================
# Colors & Formatting
# ============================================================

if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' DIM='' NC=''
fi

SYM_ARROW="${BLUE}→${NC}"

# ============================================================
# Helper Functions
# ============================================================

friendly_error() {
    local msg="$1"
    local help="$2"
    echo ""
    echo -e "  ${RED}Oops!${NC} $msg"
    echo ""
    if [ -n "$help" ]; then
        echo -e "  $help"
        echo ""
    fi
}

require_python() {
    if [ -z "$PYTHON_CMD" ]; then
        friendly_error "Tower needs Python to run." \
            "Install Python from ${CYAN}python.org/downloads${NC} and try again."
        exit 1
    fi
}

require_status() {
    if [ ! -f "$STATUS_FILE" ]; then
        mkdir -p "$CONTROL_DIR"
        echo '{"spec_version": "v1.5.7", "cards": [], "last_updated": null}' > "$STATUS_FILE"
    fi
}

detect_card() {
    local cwd="$(pwd)"
    if [[ "$cwd" == *"/worktrees/CARD-"* ]]; then
        echo "$cwd" | grep -oE 'CARD-[0-9]+' | head -1
        return 0
    fi
    if command -v git &> /dev/null && git rev-parse --git-dir &> /dev/null; then
        local branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [[ "$branch" == card/CARD-* ]]; then
            echo "$branch" | grep -oE 'CARD-[0-9]+'
            return 0
        fi
    fi
    return 1
}

prompt() {
    local question="$1"
    local default="$2"
    local result
    if [ -n "$default" ]; then
        echo -ne "  $question ${DIM}[$default]${NC}: "
    else
        echo -ne "  $question: "
    fi
    read result
    if [ -z "$result" ] && [ -n "$default" ]; then
        result="$default"
    fi
    echo "$result"
}

# ============================================================
# Commands
# ============================================================

cmd_help() {
    echo ""
    echo -e "  ${BOLD}Tower${NC} - Research Workflow Made Simple"
    echo ""
    echo -e "  ${BOLD}Commands:${NC}"
    echo ""
    echo -e "    ${CYAN}tower status${NC}              Show all cards and their state"
    echo -e "    ${CYAN}tower new${NC} [description]   Create a new card"
    echo -e "    ${CYAN}tower run${NC} \"command\"       Run a command (tracked)"
    echo -e "    ${CYAN}tower check${NC} [CARD-NNN]    Check gates for a card"
    echo -e "    ${CYAN}tower pack${NC} [CARD-NNN]     Generate proofpack"
    echo -e "    ${CYAN}tower merge${NC} [CARD-NNN]    Merge to main (if GOLD)"
    echo ""
    echo -e "  ${BOLD}Examples:${NC}"
    echo ""
    echo -e "    ${DIM}# Create a new card${NC}"
    echo -e "    tower new \"Fix Table 3 calculations\""
    echo ""
    echo -e "    ${DIM}# Run your analysis (auto-detects card)${NC}"
    echo -e "    tower run \"python analyze.py\""
    echo ""
    echo -e "    ${DIM}# Check if ready to merge${NC}"
    echo -e "    tower check"
    echo ""
    echo -e "  ${BOLD}Tips:${NC}"
    echo ""
    echo "    - Tower auto-detects your card from the worktree"
    echo "    - Run 'tower status' anytime to see progress"
    echo "    - Merge windows: 06:30-06:50 and 19:00-19:20 (London)"
    echo ""
}

cmd_status() {
    require_python
    require_status

    export _TOWER_STATUS="$STATUS_FILE"
    export _TOWER_DIR="$TOWER_DIR"

    $PYTHON_CMD - << 'PYEOF'
import json
import os
import sys
from datetime import datetime

# Fix Windows encoding
if sys.platform == "win32":
    sys.stdout.reconfigure(encoding='utf-8')

status_file = os.environ.get("_TOWER_STATUS", "")

GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
RED = "\033[0;31m"
BLUE = "\033[0;34m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
DIM = "\033[2m"
NC = "\033[0m"

def state_color(state):
    return {"GOLD": GREEN, "REVIEW": YELLOW, "DRAFT": BLUE, "MERGED": DIM}.get(state, NC)

def color_indicator(color):
    return {"GREEN": "🟢", "YELLOW": "🟡", "RED": "🔴"}.get(color, "⚪")

def gate_symbol(status):
    if status == "PASS":
        return f"{GREEN}✓{NC}"
    elif status == "FAIL":
        return f"{RED}✗{NC}"
    return f"{DIM}·{NC}"

try:
    with open(status_file) as f:
        data = json.load(f)
except:
    data = {"cards": []}

cards = data.get("cards", [])
now = datetime.now()
date_str = now.strftime("%b %d, %Y")

width = 55
print()
print(f"{CYAN}╭{'─' * width}╮{NC}")
print(f"{CYAN}│{NC}  {BOLD}TOWER STATUS{NC}" + " " * (width - 15) + f"{date_str}  {CYAN}│{NC}")
print(f"{CYAN}├{'─' * width}┤{NC}")

if not cards:
    print(f"{CYAN}│{NC}" + " " * width + f"{CYAN}│{NC}")
    print(f"{CYAN}│{NC}  {DIM}No cards yet. Create one with:{NC}" + " " * 18 + f"{CYAN}│{NC}")
    print(f"{CYAN}│{NC}  {CYAN}tower new \"My first task\"{NC}" + " " * 22 + f"{CYAN}│{NC}")
    print(f"{CYAN}│{NC}" + " " * width + f"{CYAN}│{NC}")
else:
    print(f"{CYAN}│{NC}" + " " * width + f"{CYAN}│{NC}")
    for card in cards:
        card_id = card.get("card_id", "???")
        desc = card.get("description", "")[:25]
        state = card.get("state", "DRAFT")
        color = card.get("color", "RED")
        gates = card.get("gates", {})

        indicator = color_indicator(color)
        state_col = state_color(state)
        card_line = f"  {card_id}  {desc:<25} {indicator} {state_col}{state}{NC}"
        padding = width - len(card_id) - len(desc) - len(state) - 10
        print(f"{CYAN}│{NC}{card_line}" + " " * max(0, padding) + f"{CYAN}│{NC}")

        tests = gate_symbol(gates.get("tests", "NOT_RUN"))
        validators = gate_symbol(gates.get("validators", "NOT_RUN"))
        proofpack = gate_symbol(gates.get("proofpack", "NOT_RUN"))
        gates_line = f"            Tests {tests}  Validators {validators}  Proofpack {proofpack}"
        print(f"{CYAN}│{NC}{gates_line}" + " " * 8 + f"{CYAN}│{NC}")
        print(f"{CYAN}│{NC}" + " " * width + f"{CYAN}│{NC}")

print(f"{CYAN}├{'─' * width}┤{NC}")

hour = now.hour
minute = now.minute
current_mins = hour * 60 + minute
morning_start, morning_end = 6 * 60 + 30, 6 * 60 + 50
evening_start, evening_end = 19 * 60, 19 * 60 + 20

if morning_start <= current_mins <= morning_end:
    window_msg = f"{GREEN}In merge window now!{NC} (until 06:50)"
elif evening_start <= current_mins <= evening_end:
    window_msg = f"{GREEN}In merge window now!{NC} (until 19:20)"
elif current_mins < morning_start:
    mins_until = morning_start - current_mins
    window_msg = f"Next window: 06:30 ({DIM}in {mins_until // 60}h {mins_until % 60}m{NC})"
elif current_mins < evening_start:
    mins_until = evening_start - current_mins
    window_msg = f"Next window: 19:00 ({DIM}in {mins_until // 60}h {mins_until % 60}m{NC})"
else:
    mins_until = (24 * 60 - current_mins) + morning_start
    window_msg = f"Next window: 06:30 ({DIM}in {mins_until // 60}h {mins_until % 60}m{NC})"

print(f"{CYAN}│{NC}  {window_msg}" + " " * (width - len(window_msg) + 15) + f"{CYAN}│{NC}")
print(f"{CYAN}╰{'─' * width}╯{NC}")
print()
PYEOF
}

cmd_new() {
    local description="$1"
    require_python
    require_status

    if [ -z "$description" ]; then
        echo ""
        echo -e "  ${BOLD}Create a New Card${NC}"
        echo ""
        description=$(prompt "What are you working on?")
        if [ -z "$description" ]; then
            friendly_error "Description cannot be empty."
            exit 1
        fi
    fi

    local next_num=$(export _TOWER_STATUS="$STATUS_FILE"; $PYTHON_CMD -c "
import json, os
try:
    with open(os.environ['_TOWER_STATUS']) as f:
        data = json.load(f)
    cards = data.get('cards', [])
    max_num = 0
    for c in cards:
        cid = c.get('card_id', '')
        if cid.startswith('CARD-'):
            try:
                num = int(cid.split('-')[1])
                max_num = max(max_num, num)
            except: pass
    print(f'{max_num + 1:03d}')
except:
    print('001')
")
    local card_id="CARD-$next_num"

    export _TOWER_STATUS="$STATUS_FILE"
    export _TOWER_CARD="$card_id"
    export _TOWER_DESC="$description"

    $PYTHON_CMD - << 'PYEOF'
import json
import os
from datetime import datetime

status_file = os.environ["_TOWER_STATUS"]
card_id = os.environ["_TOWER_CARD"]
description = os.environ["_TOWER_DESC"]

with open(status_file, 'r') as f:
    data = json.load(f)

cards = data.get("cards", [])
if not isinstance(cards, list):
    cards = []

cards.append({
    "card_id": card_id,
    "description": description,
    "state": "DRAFT",
    "color": "RED",
    "stream": "apps",
    "gates": {"tests": "NOT_RUN", "validators": "NOT_RUN", "proofpack": "NOT_RUN"},
    "run_ids": [],
    "created_at": datetime.now().isoformat(),
    "updated_at": datetime.now().isoformat()
})

data["cards"] = cards
data["last_updated"] = datetime.now().isoformat()

tmp_file = status_file + ".tmp"
with open(tmp_file, 'w') as f:
    json.dump(data, f, indent=2)
os.replace(tmp_file, status_file)
PYEOF

    local worktree_dir="$TOWER_DIR/worktrees/$card_id"
    mkdir -p "$worktree_dir"

    echo ""
    echo -e "  ${GREEN}✓${NC} Created ${BOLD}$card_id${NC}"
    echo ""
    echo -e "    ${DIM}Description:${NC} $description"
    echo -e "    ${DIM}Worktree:${NC}    $worktree_dir"
    echo ""
    echo "  Next steps:"
    echo -e "    ${CYAN}cd $worktree_dir${NC}"
    echo -e "    ${CYAN}tower run \"your-command\"${NC}"
    echo ""
}

cmd_run() {
    local cmd="$1"
    local card_id="$2"

    if [ -z "$cmd" ]; then
        echo ""
        echo -e "  ${BOLD}Run a Command${NC}"
        echo ""
        cmd=$(prompt "What command do you want to run?")
        if [ -z "$cmd" ]; then
            friendly_error "Command cannot be empty."
            exit 1
        fi
    fi

    if [ -z "$card_id" ]; then
        card_id=$(detect_card) || true
    fi

    if [ -z "$card_id" ]; then
        echo ""
        echo -e "  ${YELLOW}!${NC} Could not detect which card you're working on."
        echo ""
        require_python
        require_status

        local cards=$(export _TOWER_STATUS="$STATUS_FILE"; $PYTHON_CMD -c "
import json, os
with open(os.environ['_TOWER_STATUS']) as f:
    data = json.load(f)
for c in data.get('cards', []):
    if c.get('state') not in ('MERGED', 'ARCHIVED'):
        print(c.get('card_id', ''))
" 2>/dev/null)

        if [ -z "$cards" ]; then
            friendly_error "No active cards found." \
                "Create one with: ${CYAN}tower new \"description\"${NC}"
            exit 1
        fi

        echo "  Available cards:"
        echo "$cards" | while read c; do
            echo -e "    ${CYAN}$c${NC}"
        done
        echo ""
        card_id=$(prompt "Which card?" "$(echo "$cards" | head -1)")
    fi

    if ! echo "$card_id" | grep -qE '^CARD-[0-9]+$'; then
        friendly_error "Invalid card format: $card_id" \
            "Cards should be like: ${CYAN}CARD-001${NC}"
        exit 1
    fi

    echo ""
    echo -e "  ${SYM_ARROW} Running under ${BOLD}$card_id${NC}..."
    echo ""

    "$SCRIPTS_DIR/tower_run.sh" --card "$card_id" --cmd "$cmd"
}

cmd_check() {
    local card_id="$1"
    if [ -z "$card_id" ]; then
        card_id=$(detect_card) || true
    fi
    if [ -z "$card_id" ]; then
        "$SCRIPTS_DIR/tower_gatecheck.sh"
    else
        "$SCRIPTS_DIR/tower_gatecheck.sh" --card "$card_id"
    fi
}

cmd_pack() {
    local card_id="$1"
    if [ -z "$card_id" ]; then
        card_id=$(detect_card) || true
    fi
    if [ -z "$card_id" ]; then
        echo ""
        friendly_error "Could not detect which card to pack." \
            "Specify it: ${CYAN}tower pack CARD-001${NC}"
        exit 1
    fi
    "$SCRIPTS_DIR/tower_proofpack.sh" --card "$card_id"
}

cmd_merge() {
    local card_id="$1"
    local do_merge="$2"
    if [ -z "$card_id" ]; then
        card_id=$(detect_card) || true
    fi
    if [ -z "$card_id" ]; then
        echo ""
        friendly_error "Could not detect which card to merge." \
            "Specify it: ${CYAN}tower merge CARD-001${NC}"
        exit 1
    fi
    if [ "$do_merge" = "--confirm" ] || [ "$do_merge" = "-y" ]; then
        "$SCRIPTS_DIR/merge_gold.sh" --card "$card_id" --do-merge
    else
        "$SCRIPTS_DIR/merge_gold.sh" --card "$card_id"
    fi
}

cmd_version() {
    echo "Tower v1.5.7"
}

# ============================================================
# Main
# ============================================================

main() {
    local command="${1:-}"
    shift 2>/dev/null || true

    case "$command" in
        ""|help|--help|-h)
            cmd_help
            ;;
        status|s)
            cmd_status
            ;;
        new|n|create)
            cmd_new "$@"
            ;;
        run|r)
            cmd_run "$@"
            ;;
        check|c|gate|gates)
            cmd_check "$@"
            ;;
        pack|p|proofpack)
            cmd_pack "$@"
            ;;
        merge|m)
            cmd_merge "$@"
            ;;
        version|--version|-v)
            cmd_version
            ;;
        *)
            friendly_error "Unknown command: $command" \
                "Run ${CYAN}tower help${NC} to see available commands."
            exit 1
            ;;
    esac
}

main "$@"
