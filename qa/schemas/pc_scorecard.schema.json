{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tower.local/schemas/pc_scorecard.schema.json",
  "title": "PC Scorecard",
  "description": "Performance metrics per PC in the fleet",
  "type": "object",
  "required": ["spec_version", "last_updated", "pcs"],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "pcs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["pc_id"],
        "properties": {
          "pc_id": {"type": "string"},
          "online": {"type": "boolean", "default": false},
          "total_jobs": {"type": "integer", "minimum": 0, "default": 0},
          "successful_jobs": {"type": "integer", "minimum": 0, "default": 0},
          "failed_jobs": {"type": "integer", "minimum": 0, "default": 0},
          "success_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
          "avg_cpu_utilization": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
          "avg_ram_utilization": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
          "uptime_hours": {"type": ["number", "null"]},
          "last_job": {"type": ["string", "null"], "format": "date-time"},
          "last_health_check": {"type": ["string", "null"], "format": "date-time"},
          "placeholder": {"type": "boolean", "default": true}
        }
      }
    }
  }
}
