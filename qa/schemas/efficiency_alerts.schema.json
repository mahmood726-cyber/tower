{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tower://schemas/efficiency_alerts.schema.json",
  "title": "Tower Efficiency Alerts",
  "type": "object",
  "required": ["spec_version", "generated_at", "alerts"],
  "properties": {
    "spec_version": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string" },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "message", "timestamp"],
        "properties": {
          "type": { "type": "string" },
          "model": { "type": "string" },
          "stream": { "type": "string" },
          "utilization": { "type": "number" },
          "target": { "type": "number" },
          "ready_count": { "type": "integer" },
          "minimum": { "type": "integer" },
          "message": { "type": "string" },
          "timestamp": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
