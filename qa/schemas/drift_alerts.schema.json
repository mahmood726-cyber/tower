{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tower://schemas/drift_alerts.schema.json",
  "title": "Tower Drift Alerts",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["type", "timestamp"],
    "properties": {
      "type": { "type": "string" },
      "metric": { "type": "string" },
      "value": { "type": "number" },
      "threshold": { "type": "number" },
      "message": { "type": "string" },
      "timestamp": { "type": "string" }
    },
    "additionalProperties": true
  }
}
