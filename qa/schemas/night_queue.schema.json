{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tower.local/schemas/night_queue.schema.json",
  "title": "Night Queue",
  "description": "Night-safe batch jobs queue",
  "type": "object",
  "required": ["spec_version", "last_updated", "jobs"],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "window": {
      "type": "object",
      "properties": {
        "start": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$"},
        "end": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$"}
      }
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["job_id", "command", "status"],
        "properties": {
          "job_id": {"type": "string"},
          "card_id": {"type": ["string", "null"], "pattern": "^CARD-[0-9]+$"},
          "command": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "skipped"]
          },
          "priority": {"type": "integer", "minimum": 1, "default": 100},
          "added_at": {"type": "string", "format": "date-time"},
          "started_at": {"type": ["string", "null"], "format": "date-time"},
          "completed_at": {"type": ["string", "null"], "format": "date-time"},
          "exit_code": {"type": ["integer", "null"]},
          "run_id": {"type": ["string", "null"]},
          "safe_batch": {"type": "boolean", "default": true}
        }
      }
    }
  }
}
