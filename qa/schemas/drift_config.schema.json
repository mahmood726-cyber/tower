{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tower.local/schemas/drift_config.schema.json",
  "title": "Drift Configuration",
  "description": "Drift detection thresholds and settings",
  "type": "object",
  "required": ["spec_version", "timezone", "thresholds", "heartbeat"],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "timezone": {
      "type": "string",
      "default": "Europe/London"
    },
    "thresholds": {
      "type": "object",
      "required": ["interactive", "pipeline", "batch"],
      "properties": {
        "interactive": {
          "type": "integer",
          "minimum": 1,
          "description": "Minutes before drift alert for interactive tasks"
        },
        "pipeline": {
          "type": "integer",
          "minimum": 1,
          "description": "Minutes before drift alert for pipeline tasks"
        },
        "batch": {
          "type": "integer",
          "minimum": 1,
          "description": "Minutes before drift alert for batch tasks"
        }
      }
    },
    "heartbeat": {
      "type": "object",
      "required": ["interval_seconds", "stale_threshold_seconds"],
      "properties": {
        "interval_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 60
        },
        "stale_threshold_seconds": {
          "type": "integer",
          "minimum": 1,
          "default": 120
        }
      }
    },
    "alert_rate_limit": {
      "type": "object",
      "properties": {
        "per_card_per_hour": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      }
    },
    "merge_windows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "start": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$"},
          "end": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$"}
        }
      }
    }
  }
}
