{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tower.local/schemas/run_context.schema.json",
  "title": "Run Context",
  "description": "Context for a single run execution",
  "type": "object",
  "required": ["run_id", "card_id", "start_time", "spec_version"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}_[0-9]{6}_[a-f0-9]+$"
    },
    "card_id": {
      "type": "string",
      "pattern": "^CARD-[0-9]+$"
    },
    "session": {
      "type": ["string", "null"]
    },
    "model": {
      "type": ["string", "null"]
    },
    "command": {
      "type": ["string", "null"]
    },
    "start_time": {
      "type": "string",
      "format": "date-time"
    },
    "working_dir": {
      "type": ["string", "null"]
    },
    "git_sha": {
      "type": ["string", "null"]
    },
    "git_branch": {
      "type": ["string", "null"]
    },
    "spec_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "machine": {
      "type": ["string", "null"]
    },
    "environment": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    }
  }
}
