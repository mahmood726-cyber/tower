<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TowerJS v0.1</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #0c0f14;
        --bg-soft: #121723;
        --panel: #151c2b;
        --panel-edge: #2b3550;
        --accent: #f3a447;
        --accent-2: #4bd0c1;
        --accent-3: #ff7b6b;
        --text: #f3f6ff;
        --muted: #a6b0c8;
        --ok: #4bd0c1;
        --warn: #f3c247;
        --err: #ff7b6b;
        --code: #1c2538;
        --shadow: 0 25px 60px rgba(4, 8, 20, 0.55);
        --radius: 18px;
        --radius-sm: 10px;
        --font-main: "Avenir Next", "Gill Sans", "Trebuchet MS", sans-serif;
        --font-mono: "Courier Prime", "Courier New", monospace;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: var(--font-main);
        background: radial-gradient(circle at top left, #1c2436, var(--bg)),
          radial-gradient(circle at 80% 20%, #1b2a3d, transparent 60%),
          linear-gradient(120deg, #0d121b 0%, #12182a 50%, #0b1018 100%);
        color: var(--text);
        min-height: 100vh;
      }

      .orb {
        position: fixed;
        width: 480px;
        height: 480px;
        background: radial-gradient(circle, rgba(243, 164, 71, 0.25), transparent 70%);
        top: -180px;
        right: -120px;
        filter: blur(10px);
        z-index: 0;
      }

      .app {
        position: relative;
        z-index: 1;
        padding: 48px clamp(16px, 4vw, 60px) 72px;
        max-width: 1200px;
        margin: 0 auto;
      }

      header.hero {
        display: flex;
        flex-wrap: wrap;
        gap: 24px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
      }

      header h1 {
        font-size: clamp(2rem, 4vw, 3.5rem);
        margin: 0 0 12px;
        letter-spacing: 0.02em;
      }

      .tagline {
        color: var(--muted);
        font-size: 1.05rem;
        max-width: 520px;
      }

      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .chip {
        background: rgba(243, 164, 71, 0.12);
        border: 1px solid rgba(243, 164, 71, 0.4);
        color: var(--accent);
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 18px;
      }

      .panel {
        background: linear-gradient(160deg, rgba(33, 42, 66, 0.92), rgba(16, 22, 35, 0.98));
        border: 1px solid rgba(70, 84, 120, 0.4);
        border-radius: var(--radius);
        padding: 22px;
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
      }

      .panel::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top left, rgba(75, 208, 193, 0.15), transparent 65%);
        opacity: 0.35;
        pointer-events: none;
      }

      .panel h2 {
        margin: 0 0 14px;
        font-size: 1.35rem;
      }

      .panel p {
        color: var(--muted);
        margin: 0 0 16px;
      }

      .status {
        margin-top: 10px;
        padding: 10px 14px;
        border-radius: var(--radius-sm);
        background: rgba(28, 37, 56, 0.6);
        border: 1px solid rgba(60, 76, 110, 0.6);
        font-size: 0.95rem;
      }

      .status[data-status="ok"] {
        border-color: rgba(75, 208, 193, 0.7);
        color: var(--ok);
      }

      .status[data-status="warn"] {
        border-color: rgba(243, 194, 71, 0.7);
        color: var(--warn);
      }

      .status[data-status="error"] {
        border-color: rgba(255, 123, 107, 0.7);
        color: var(--err);
      }

      label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      input[type="text"],
      textarea,
      select {
        width: 100%;
        padding: 10px 12px;
        margin-top: 6px;
        border-radius: var(--radius-sm);
        border: 1px solid rgba(70, 84, 120, 0.7);
        background: rgba(12, 16, 26, 0.8);
        color: var(--text);
        font-family: var(--font-main);
      }

      textarea {
        min-height: 90px;
        font-family: var(--font-mono);
      }

      .row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
      }

      button {
        border: none;
        border-radius: 999px;
        padding: 10px 18px;
        background: var(--accent);
        color: #241508;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      button.secondary {
        background: transparent;
        color: var(--accent);
        border: 1px solid rgba(243, 164, 71, 0.6);
      }

      button:hover {
        transform: translateY(-1px);
        box-shadow: 0 10px 18px rgba(243, 164, 71, 0.2);
      }

      .mono {
        font-family: var(--font-mono);
        font-size: 0.9rem;
      }

      .issue-list {
        list-style: none;
        padding: 0;
        margin: 12px 0 0;
      }

      .issue-list li {
        padding: 8px 10px;
        border-radius: 8px;
        background: rgba(18, 25, 40, 0.8);
        margin-bottom: 8px;
        border: 1px solid rgba(60, 76, 110, 0.45);
      }

      .issue-list li[data-level="error"] {
        border-color: rgba(255, 123, 107, 0.5);
        color: var(--err);
      }

      .issue-list li[data-level="warn"] {
        border-color: rgba(243, 194, 71, 0.5);
        color: var(--warn);
      }

      .issue-list li[data-level="info"] {
        border-color: rgba(75, 208, 193, 0.5);
        color: var(--ok);
      }

      .output {
        background: var(--code);
        border-radius: var(--radius-sm);
        padding: 12px;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: #c8d1ef;
        white-space: pre-wrap;
        min-height: 70px;
      }

      .download {
        margin-top: 12px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--accent-2);
        text-decoration: none;
        font-weight: 600;
      }

      .fade-in {
        animation: fadeIn 0.8s ease both;
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 640px) {
        header.hero {
          flex-direction: column;
          align-items: flex-start;
        }

        .panel {
          padding: 18px;
        }
      }
    </style>
  </head>
  <body>
    <div class="orb"></div>
    <div class="app fade-in">
      <header class="hero">
        <div>
          <h1>TowerJS v0.1</h1>
          <div class="tagline">
            Browser-first Tower tools: scan control files, write trace DBs, and
            build tamper-evident proofpacks. Offline, no server.
          </div>
        </div>
        <div class="chips">
          <div class="chip">Offline</div>
          <div class="chip">Ed25519</div>
          <div class="chip">Proofpack</div>
        </div>
      </header>

      <section class="panel" id="connect-panel">
        <h2>Connect Tower Folder</h2>
        <p>
          Choose a directory for full read/write (File System Access API) or
          upload a folder for read-only scans.
        </p>
        <div class="grid">
          <div>
            <button id="pick-folder">Pick Tower Folder</button>
            <div class="status" id="picker-status" data-status="warn">
              File System Access API required for write access.
            </div>
          </div>
          <div>
            <label for="folder-upload">Folder Upload (read-only)</label>
            <input id="folder-upload" type="file" webkitdirectory multiple />
            <div class="status" id="upload-status" data-status="warn">
              No folder selected.
            </div>
          </div>
        </div>
        <div class="status" id="connect-status" data-status="warn">
          Not connected.
        </div>
      </section>

      <section class="panel" id="scan-panel">
        <h2>Control Scan</h2>
        <p>Validates Tower control files against strict schemas.</p>
        <div class="row">
          <button id="scan-btn">Run Scan</button>
          <div class="mono" id="file-count">Files: 0</div>
        </div>
        <div class="status" id="scan-status" data-status="warn">
          No scan yet.
        </div>
        <ul class="issue-list" id="scan-issues"></ul>
      </section>

      <section class="panel" id="trace-panel">
        <h2>Trace DB (NDJSON)</h2>
        <p>Read or append trace entries to the file-based trace DB.</p>
        <label for="trace-path">Trace DB Path</label>
        <input id="trace-path" type="text" value="control/trace_db.jsonl" />
        <div class="row" style="margin-top: 12px;">
          <button id="trace-load">Load Trace</button>
        </div>
        <div class="status" id="trace-status" data-status="warn">
          Trace not loaded.
        </div>
        <div class="output" id="trace-output">No entries loaded.</div>
        <div style="margin-top: 16px;">
          <label for="trace-event">Event</label>
          <input id="trace-event" type="text" placeholder="card.move" />
          <label for="trace-source" style="margin-top: 10px;">Source</label>
          <input id="trace-source" type="text" placeholder="tower-ui" />
          <label for="trace-message" style="margin-top: 10px;">Message</label>
          <input id="trace-message" type="text" placeholder="Moved card to Done" />
          <label for="trace-level" style="margin-top: 10px;">Level</label>
          <select id="trace-level">
            <option value="">(optional)</option>
            <option value="debug">debug</option>
            <option value="info">info</option>
            <option value="warn">warn</option>
            <option value="error">error</option>
          </select>
          <button id="trace-append" style="margin-top: 12px;">
            Append Trace Entry
          </button>
        </div>
      </section>

      <section class="panel" id="proof-panel">
        <h2>Proofpack Builder</h2>
        <p>Build a manifest, hash tree, and signed zip bundle.</p>
        <label for="include-prefixes">Include Prefixes (comma separated)</label>
        <input id="include-prefixes" type="text" placeholder="control/, knowledge/" />
        <label for="exclude-prefixes" style="margin-top: 10px;">Exclude Prefixes</label>
        <input
          id="exclude-prefixes"
          type="text"
          value=".git/, node_modules/, tower_js/, dist/"
        />
        <label for="exclude-names" style="margin-top: 10px;">Exclude Names</label>
        <input
          id="exclude-names"
          type="text"
          value="hash_tree.json, signature.txt, public_key.txt, proofpack.zip"
        />
        <label for="zip-name" style="margin-top: 10px;">Zip Name</label>
        <input id="zip-name" type="text" value="proofpack.zip" />
        <div class="grid" style="margin-top: 14px;">
          <div>
            <label for="public-key">Public Key (base64 raw)</label>
            <textarea id="public-key" placeholder="Paste or generate"></textarea>
          </div>
          <div>
            <label for="private-key">Private Key (base64 pkcs8)</label>
            <textarea id="private-key" placeholder="Paste or generate"></textarea>
          </div>
        </div>
        <div class="row" style="margin-top: 12px;">
          <button class="secondary" id="gen-keys">Generate Keypair</button>
          <button class="secondary" id="load-keys">Use Keys</button>
        </div>
        <div class="row" style="margin-top: 12px;">
          <button id="build-proofpack">Build Proofpack</button>
        </div>
        <div class="status" id="proof-status" data-status="warn">
          No proofpack built yet.
        </div>
        <div class="output" id="proof-output">Waiting for build.</div>
        <a class="download" id="proof-download" href="#" download>Download</a>
      </section>
    </div>
    <script>
// ajv.min.js
