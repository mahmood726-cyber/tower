#!/usr/bin/env bash
#
# Tower CLI - Research Workflow Made Simple
#
# Usage:
#   tower status          Show all cards
#   tower new [desc]      Create a new card
#   tower run "cmd"       Run a command under current card
#   tower check [card]    Check gates for a card
#   tower pack [card]     Generate proofpack
#   tower merge [card]    Merge a GOLD card (in merge window)
#   tower help            Show help
#

set -e

# ============================================================
# Configuration
# ============================================================

TOWER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TOWER_DIR/scripts"
CONTROL_DIR="$TOWER_DIR/control"
STATUS_FILE="$CONTROL_DIR/status.json"

# Detect Python
if command -v python3 &> /dev/null; then
    PYTHON_CMD="python3"
elif command -v python &> /dev/null; then
    PYTHON_CMD="python"
else
    PYTHON_CMD=""
fi

# ============================================================
# Colors & Formatting
# ============================================================

if [ -t 1 ] && [ -n "$TERM" ] && [ "$TERM" != "dumb" ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' DIM='' NC=''
fi

SYM_ARROW="${BLUE}→${NC}"

# ============================================================
# Helper Functions
# ============================================================

friendly_error() {
    local msg="$1"
    local help="$2"
    echo ""
    echo -e "  ${RED}Oops!${NC} $msg"
    echo ""
    if [ -n "$help" ]; then
        echo -e "  $help"
        echo ""
    fi
}

require_python() {
    if [ -z "$PYTHON_CMD" ]; then
        friendly_error "Tower needs Python to run." \
            "Install Python from ${CYAN}python.org/downloads${NC} and try again."
        exit 1
    fi
}

require_status() {
    if [ ! -f "$STATUS_FILE" ]; then
        mkdir -p "$CONTROL_DIR"
        local now=$(date -Iseconds 2>/dev/null || date +%Y-%m-%dT%H:%M:%S)
        echo "{\"spec_version\": \"v1.5.7\", \"cards\": [], \"last_updated\": \"$now\"}" > "$STATUS_FILE"
    fi
}

detect_card() {
    local cwd="$(pwd)"
    if [[ "$cwd" == *"/worktrees/CARD-"* ]]; then
        echo "$cwd" | grep -oE 'CARD-[0-9]+' | head -1
        return 0
    fi
    if command -v git &> /dev/null && git rev-parse --git-dir &> /dev/null; then
        local branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [[ "$branch" == card/CARD-* ]]; then
            echo "$branch" | grep -oE 'CARD-[0-9]+'
            return 0
        fi
    fi
    return 1
}

prompt() {
    local question="$1"
    local default="$2"
    local result
    if [ -n "$default" ]; then
        echo -ne "  $question ${DIM}[$default]${NC}: "
    else
        echo -ne "  $question: "
    fi
    read result
    if [ -z "$result" ] && [ -n "$default" ]; then
        result="$default"
    fi
    echo "$result"
}

# ============================================================
# Commands
# ============================================================

