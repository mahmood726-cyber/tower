main() {
    local command="${1:-}"
    shift 2>/dev/null || true

    case "$command" in
        ""|help|--help|-h)
            cmd_help
            ;;
        status|s)
            cmd_status
            ;;
        new|n|create)
            cmd_new "$@"
            ;;
        run|r)
            cmd_run "$@"
            ;;
        check|c|gate|gates)
            cmd_check "$@"
            ;;
        pack|p|proofpack)
            cmd_pack "$@"
            ;;
        merge|m)
            cmd_merge "$@"
            ;;
        drift|d)
            cmd_drift
            ;;
        health|h)
            cmd_health
            ;;
        rules)
            cmd_rules
            ;;
        version|--version|-v)
            cmd_version
            ;;
        *)
            friendly_error "Unknown command: $command" \
                "Run ${CYAN}tower help${NC} to see available commands."
            exit 1
            ;;
    esac
}

main "$@"
