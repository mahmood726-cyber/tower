cmd_status() {
    require_python
    require_status

    export _TOWER_STATUS="$STATUS_FILE"
    export _TOWER_DIR="$TOWER_DIR"

    $PYTHON_CMD - << 'PYEOF'
import json
import os
import re
import sys
from datetime import datetime

# Fix Windows encoding
if sys.platform == "win32":
    sys.stdout.reconfigure(encoding='utf-8')

status_file = os.environ.get("_TOWER_STATUS", "")

GREEN = "\033[0;32m"
YELLOW = "\033[1;33m"
RED = "\033[0;31m"
BLUE = "\033[0;34m"
CYAN = "\033[0;36m"
BOLD = "\033[1m"
DIM = "\033[2m"
NC = "\033[0m"

# Helper to calculate visible width (strips ANSI codes, accounts for emoji width)
_ansi_pattern = re.compile(r'\x1b\[[0-9;]*m')
_emoji_pattern = re.compile(r'[\U0001F300-\U0001F9FF]')

def visible_width(s):
    """Calculate visible width of string, accounting for ANSI codes and emojis."""
    plain = _ansi_pattern.sub('', s)
    # Emojis typically render as 2 characters wide
    emoji_count = len(_emoji_pattern.findall(plain))
    return len(plain) + emoji_count  # +1 extra per emoji for double-width

def state_color(state):
    return {"GOLD": GREEN, "REVIEW": YELLOW, "DRAFT": BLUE, "MERGED": DIM}.get(state, NC)

def color_indicator(color):
    return {"GREEN": "🟢", "YELLOW": "🟡", "RED": "🔴"}.get(color, "⚪")

def assurance_badge(level):
    """TruthCert assurance level badge."""
    badges = {
        "gold": f"{YELLOW}🏆{NC}",
        "silver": f"{DIM}🥈{NC}",
        "bronze": f"{DIM}🥉{NC}",
        "none": f"{DIM}·{NC}",
    }
    return badges.get(level, badges["none"])

def gate_symbol(status):
    # Handle new format: {"status": "PASS", "severity": "P0"}
    if isinstance(status, dict):
        status = status.get("status", "NOT_RUN")
    if status == "PASS":
        return f"{GREEN}✓{NC}"
    elif status == "FAIL":
        return f"{RED}✗{NC}"
    elif status == "BLOCKED":
        return f"{RED}⊘{NC}"
    return f"{DIM}·{NC}"

try:
    with open(status_file) as f:
        data = json.load(f)
except:
    data = {"cards": []}

cards = data.get("cards", [])
now = datetime.now()
date_str = now.strftime("%b %d, %Y")

width = 55
print()
print(f"{CYAN}╭{'─' * width}╮{NC}")
print(f"{CYAN}│{NC}  {BOLD}TOWER STATUS{NC}" + " " * (width - 15) + f"{date_str}  {CYAN}│{NC}")
print(f"{CYAN}├{'─' * width}┤{NC}")

if not cards:
    print(f"{CYAN}│{NC}" + " " * width + f"{CYAN}│{NC}")
    print(f"{CYAN}│{NC}  {DIM}No cards yet. Create one with:{NC}" + " " * 18 + f"{CYAN}│{NC}")
    print(f"{CYAN}│{NC}  {CYAN}tower new \"My first task\"{NC}" + " " * 22 + f"{CYAN}│{NC}")
    print(f"{CYAN}│{NC}" + " " * width + f"{CYAN}│{NC}")
else:
    print(f"{CYAN}│{NC}" + " " * width + f"{CYAN}│{NC}")
    for card in cards:
        card_id = card.get("card_id", "???")
        desc = card.get("description", "")[:25]
        state = card.get("state", "DRAFT")
        color = card.get("color", "RED")
        gates = card.get("gates", {})
        assurance = card.get("assurance", "none")

        indicator = color_indicator(color)
        state_col = state_color(state)
        badge = assurance_badge(assurance)
        card_line = f"  {card_id}  {desc:<25} {indicator} {state_col}{state}{NC} {badge}"
        padding = width - visible_width(card_line)
        print(f"{CYAN}│{NC}{card_line}" + " " * max(0, padding) + f"{CYAN}│{NC}")

        tests = gate_symbol(gates.get("tests", "NOT_RUN"))
        validators = gate_symbol(gates.get("validators", "NOT_RUN"))
        proofpack = gate_symbol(gates.get("proofpack", "NOT_RUN"))
        gates_line = f"            Tests {tests}  Validators {validators}  Proofpack {proofpack}"
        padding = width - visible_width(gates_line)
        print(f"{CYAN}│{NC}{gates_line}" + " " * max(0, padding) + f"{CYAN}│{NC}")
        print(f"{CYAN}│{NC}" + " " * width + f"{CYAN}│{NC}")

print(f"{CYAN}├{'─' * width}┤{NC}")

hour = now.hour
minute = now.minute
current_mins = hour * 60 + minute
morning_start, morning_end = 6 * 60 + 30, 6 * 60 + 50
evening_start, evening_end = 19 * 60, 19 * 60 + 20

if morning_start <= current_mins <= morning_end:
    window_msg = f"{GREEN}In merge window now!{NC} (until 06:50)"
elif evening_start <= current_mins <= evening_end:
    window_msg = f"{GREEN}In merge window now!{NC} (until 19:20)"
elif current_mins < morning_start:
    mins_until = morning_start - current_mins
    window_msg = f"Next window: 06:30 ({DIM}in {mins_until // 60}h {mins_until % 60}m{NC})"
elif current_mins < evening_start:
    mins_until = evening_start - current_mins
    window_msg = f"Next window: 19:00 ({DIM}in {mins_until // 60}h {mins_until % 60}m{NC})"
else:
    mins_until = (24 * 60 - current_mins) + morning_start
    window_msg = f"Next window: 06:30 ({DIM}in {mins_until // 60}h {mins_until % 60}m{NC})"

padding = width - visible_width(f"  {window_msg}")
print(f"{CYAN}│{NC}  {window_msg}" + " " * max(0, padding) + f"{CYAN}│{NC}")
print(f"{CYAN}╰{'─' * width}╯{NC}")
print()
PYEOF
}

