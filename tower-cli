    $PYTHON_CMD - << 'PYEOF'
import json
import os
import sys
from datetime import datetime, timedelta

if sys.platform == "win32":
    sys.stdout.reconfigure(encoding='utf-8')

drift_file = os.environ.get("_TOWER_DRIFT", "")
if not drift_file:
    sys.exit(0)

try:
    with open(drift_file) as f:
        data = json.load(f)
except:
    print("  No drift data")
    sys.exit(0)

events = data.get("events", [])
now = datetime.now()
week_ago = now - timedelta(days=7)

# Count by severity
p0_count = sum(1 for e in events if e.get("severity") == "P0")
p1_count = sum(1 for e in events if e.get("severity") == "P1")
p2_count = sum(1 for e in events if e.get("severity") == "P2")
unadj = sum(1 for e in events if not e.get("adjudicated", False))

print(f"  Total events: {len(events)}")
print(f"  P0 (Block):   {p0_count}")
print(f"  P1 (Warn):    {p1_count}")
print(f"  P2 (Info):    {p2_count}")
print(f"  Unadjudicated: {unadj}")
print()

# Recent events
print("  Recent drift events:")
for e in events[-5:]:
    sev = e.get("severity", "??")
    card = e.get("card_id", "???")
    field = e.get("field", "")
    old = e.get("old_value", "")
    new = e.get("new_value", "")
    adj = "✓" if e.get("adjudicated") else "·"
    print(f"    [{sev}] {card}: {field} {old} → {new} {adj}")
print()
PYEOF
}

cmd_health() {
    require_python

    echo ""
    echo -e "  ${BOLD}System Health${NC} (TruthCert Circuit Breaker)"
    echo ""

    local drift_ledger="$CONTROL_DIR/drift_ledger.json"

    export _TOWER_DRIFT="$drift_ledger"
    $PYTHON_CMD - << 'PYEOF'
import json
import os
import sys
from datetime import datetime, timedelta

if sys.platform == "win32":
    sys.stdout.reconfigure(encoding='utf-8')

GREEN = "\033[0;32m"
RED = "\033[0;31m"
YELLOW = "\033[1;33m"
NC = "\033[0m"

drift_file = os.environ.get("_TOWER_DRIFT", "")

# Thresholds
MAX_P0 = 3
MAX_UNADJ = 10

p0_failures = 0
unadjudicated = 0

if drift_file and os.path.exists(drift_file):
    try:
        with open(drift_file) as f:
            data = json.load(f)
        events = data.get("events", [])
        now = datetime.now()
        week_ago = now - timedelta(days=7)

        for e in events:
            if e.get("severity") == "P0":
                try:
                    ts = e.get("timestamp", "")
                    if ts:
                        # Handle Z, +HH:MM, and -HH:MM timezone formats
                        if ts.endswith("Z"):
                            ts = ts[:-1]
                        if "+" in ts and "T" in ts:
                            ts = ts.split("+")[0]
                        elif ts.count("-") > 2 and "T" in ts:
                            # -HH:MM timezone (not the date dashes)
                            parts = ts.split("T")
                            time_part = parts[1].split("-")[0] if "-" in parts[1] else parts[1]
                            ts = parts[0] + "T" + time_part
                        # Remove milliseconds
                        ts = ts.split(".")[0]
                        event_time = datetime.fromisoformat(ts)
                        if event_time > week_ago:
                            p0_failures += 1
                except:
                    pass
            if not e.get("adjudicated", False):
                unadjudicated += 1
    except:
        pass

# Check health
issues = []
if p0_failures >= MAX_P0:
    issues.append(f"P0 failures ({p0_failures}) >= threshold ({MAX_P0})")
if unadjudicated >= MAX_UNADJ:
    issues.append(f"Unadjudicated ({unadjudicated}) >= threshold ({MAX_UNADJ})")

if issues:
    print(f"  Status: {RED}DEGRADED{NC}")
    print(f"  Merges: {RED}BLOCKED{NC}")
    print()
    print("  Issues:")
    for issue in issues:
        print(f"    - {issue}")
else:
    print(f"  Status: {GREEN}HEALTHY{NC}")
    print(f"  Merges: {GREEN}ALLOWED{NC}")
    print()
    print(f"  P0 failures (7d): {p0_failures}/{MAX_P0}")
    print(f"  Unadjudicated:    {unadjudicated}/{MAX_UNADJ}")

print()
PYEOF
}

