# Tower Add-ons Environment Configuration
# Copy this file to ~/.tower_addons.env and source it
# NEVER commit actual secrets to the repository

# =============================================================================
# ADD-ON ENABLE FLAGS (0 = disabled, 1 = enabled)
# =============================================================================

# Enable Prefect orchestration (local mode, no cloud required)
TOWER_ADDONS_ENABLE_PREFECT=0

# Enable MLflow run tracking (local file store)
TOWER_ADDONS_ENABLE_MLFLOW=0

# Enable LangSmith tracing (requires API key)
TOWER_ADDONS_ENABLE_TRACING=0

# =============================================================================
# MLFLOW CONFIGURATION (Local by default)
# =============================================================================

# Local file-based tracking URI (default, no server needed)
MLFLOW_TRACKING_URI=file:./tower/addons/mlflow/state/mlruns

# Experiment name for Tower runs
MLFLOW_EXPERIMENT_NAME=Tower

# Optional: Remote tracking server (leave empty for local)
# MLFLOW_TRACKING_URI=http://localhost:5000

# =============================================================================
# LANGSMITH CONFIGURATION (Disabled by default)
# =============================================================================

# LangSmith API key (leave empty to disable)
# Get yours at: https://smith.langchain.com/
LANGSMITH_API_KEY=

# Project name for Tower traces
LANGSMITH_PROJECT=Tower

# Optional: Custom endpoint (leave empty for default)
LANGSMITH_ENDPOINT=

# Tracing mode: "metadata_only" (default) or "full"
# metadata_only: Only trace run metadata, not prompt contents
# full: Include prompt contents (use with caution)
LANGSMITH_TRACING_MODE=metadata_only

# =============================================================================
# PREFECT CONFIGURATION (Local by default)
# =============================================================================

# Prefect API URL (leave empty for local ephemeral mode)
PREFECT_API_URL=

# Optional: Prefect Cloud workspace (leave empty for local)
# PREFECT_API_KEY=
# PREFECT_WORKSPACE=

# =============================================================================
# GENERAL ADD-ON SETTINGS
# =============================================================================

# Verbosity: 0=quiet, 1=normal, 2=debug
TOWER_ADDONS_VERBOSITY=1

# Auto-cleanup old receipts after N days (0 = never)
TOWER_ADDONS_RECEIPT_RETENTION_DAYS=30
