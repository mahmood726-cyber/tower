# Tower Bridge Configuration
# Copy to .env and set your values

# Enable LangSmith local tracing
TOWER_BRIDGE_LANGSMITH_ENABLE=1

# Enable MLflow logging
TOWER_BRIDGE_MLFLOW_ENABLE=1

# MLflow tracking store location
MLFLOW_TRACKING_URI=file:./tower/addons/mlflow/mlruns

# MLflow experiment name
MLFLOW_EXPERIMENT_NAME=tower

# LangSmith project name
LANGSMITH_PROJECT=tower

# Enable remote LangSmith tracing (requires API key)
TOWER_LANGSMITH_ENABLE=0

# LangSmith API key (for remote tracing)
LANGSMITH_API_KEY=
