# LangSmith Configuration for Tower
# Copy to .env and set your values

# API key for remote tracing (leave empty for local-only)
LANGSMITH_API_KEY=

# Project name in LangSmith
LANGSMITH_PROJECT=tower

# LangSmith API endpoint
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Enable remote tracing (0=off, 1=on)
TOWER_LANGSMITH_ENABLE=0
